; external perimeters extrusion width = 0.42mm
; perimeters extrusion width = 0.45mm
; infill extrusion width = 0.45mm
; solid infill extrusion width = 0.42mm
; top infill extrusion width = 0.42mm
; support material extrusion width = 0.40mm
; first layer extrusion width = 0.50mm

; EXECUTABLE_BLOCK_START
M73 P0 R36
M201 X5000 Y5000 Z500 E5000
M203 X500 Y500 Z30 E100
M204 P5000 R2500 T5000 ; sets acceleration (P, T) and retract acceleration (R), mm/sec^2
M205 X10.00 Y10.00 Z0.40 E5.00 ; sets the jerk limits, mm/sec
; max_print_temp = 50,190
;TYPE:Custom
M220 S100 ;Reset Feedrate 
M221 S100 ;Reset Flowrate 
 
M140 S50 ;Set final bed temp 
G28 ;Home 
 
G92 E0 ;Reset Extruder 
G1 Z2.0 F3000 ;Move Z Axis up 
M104 S190 ;Set final nozzle temp 
G1 X-2.1 Y20 Z0.28 F5000.0 ;Move to start position 
M190 S50 ;Wait for bed temp to stabilize 
M109 S190 ;Wait for nozzle temp to stabilize 
G1 X-2.1 Y145.0 Z0.28 F1500.0 E15 ;Draw the first line 
G1 X-2.4 Y145.0 Z0.28 F5000.0 ;Move to side a little 
M73 P0 R35
G1 X-2.4 Y20 Z0.28 F1500.0 E30 ;Draw the second line 
G92 E0  ;Reset Extruder 
G1 E-1.0000 F1800 ;Retract a bit 
G1 Z2.0 F3000 ;Move Z Axis up 
G1 E0.0000 F1800
G90
G21
M83 ; use relative distances for extrusion
;filament start gcode
G1 E-1.2 F2400
G1 Z.2 F9000
M106 S0
;LAYER_CHANGE
;Z:0.2
;HEIGHT:0.2
;BEFORE_LAYER_CHANGE
;0.2
G92 E0

;_SET_FAN_SPEED_CHANGING_LAYER
M204 P500
M205 X10 Y10
